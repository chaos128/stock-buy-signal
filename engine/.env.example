# 엔진 런타임 환경변수 템플릿.
# 이 파일을 복사해 .env 로 만들고 값을 채운다:   cp .env.example .env
# .env 는 gitignore 됨 — 절대 커밋 금지. Secret/API 키는 비밀번호처럼 취급.

# --- Supabase (엔진이 service-role 로 write; RLS 우회) ---
# URL: 이 프로젝트는 아래 값 고정.
# Secret key: Supabase 대시보드 > Project Settings > API Keys
#             > "Secret keys" > default > Reveal 후 복사 (sb_secret_...)
SUPABASE_URL=https://wgjjucqitnnjzdbxtcxg.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxx

# --- Resend (이메일 발송) ---
# resend.com 가입 > API Keys > Create API Key > 복사 (re_...). 무료 티어 월 3000통.
RESEND_API_KEY=re_xxx
# 발신 주소. 도메인 인증 전 테스트는 onboarding@resend.dev 사용 가능(본인 계정 이메일로만 발송됨).
# 공개/실사용 시 자기 도메인 인증(SPF/DKIM) 후 그 도메인 주소로 교체.
RESEND_FROM_EMAIL=onboarding@resend.dev
